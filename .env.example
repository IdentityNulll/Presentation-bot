# Database connection url (MongoDB)
DATABASE_URL="mongodb://admin:adminpassword@localhost:27017/slidepaw?authSource=admin"

# Telegram Bot Token (obtain from @BotFather)
TELEGRAM_BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"

# JWT Secret for dashboard admin token generation
